{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Time between fix releases after v1.1.0",
  "width": 500,
  "height": 200,
  "title": "Minutes between fix releases (longer = fewer escaped bugs)",
  "data": {
    "values": [
      {"release": "v1.1.1", "fix": "Homebrew cask config", "minutes": 9},
      {"release": "v1.1.2", "fix": "Terminal background bleed-through", "minutes": 46},
      {"release": "v1.1.3", "fix": "Brew tap URL, cm help display", "minutes": 60},
      {"release": "v1.1.4", "fix": "Formatter per-line results", "minutes": 16},
      {"release": "v1.1.5", "fix": "Duplicate autocomplete functions", "minutes": 589}
    ]
  },
  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3
  },
  "encoding": {
    "x": {
      "field": "release",
      "type": "nominal",
      "sort": null,
      "axis": {"title": null, "labelAngle": 0}
    },
    "y": {
      "field": "minutes",
      "type": "quantitative",
      "axis": {"title": "Minutes between releases"},
      "scale": {"type": "sqrt"}
    },
    "color": {
      "field": "minutes",
      "type": "quantitative",
      "scale": {"scheme": "greens"},
      "legend": null
    },
    "tooltip": [
      {"field": "release", "title": "Release"},
      {"field": "fix", "title": "Fix"},
      {"field": "minutes", "title": "Minutes since last fix"}
    ]
  }
}
