      "type": "quantitative",
      "scale": {"scheme": "orangered", "reverse": true},
      "legend": null
    },
    "tooltip": [
      {"field": "issue", "title": "Issue"},
      {"field": "title", "title": "Title"},
      {"field": "hours", "title": "Lead time (hours)"}
