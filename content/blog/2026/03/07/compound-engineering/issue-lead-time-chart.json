      {"issue": "#23", "title": "IO broken on piped eval", "hours": 0.9},
      {"issue": "#27", "title": "Make examples linkable", "hours": 1.0},
      {"issue": "#33", "title": "CommonMark/GFM coverage", "hours": 1.2},
      {"issue": "#14", "title": "Space before kg unit", "hours": 1.3},
      {"issue": "#16", "title": "Currency + number fails", "hours": 1.4},
      {"issue": "#15", "title": "Autosuggest not on undo stack", "hours": 2.0},
      {"issue": "#26", "title": "Wrapped preview pane styling", "hours": 3.1},
      {"issue": "#12", "title": "Multi-byte character support", "hours": 4.3},
