# Local dev environment. Copy to .env and fill in.
# Taskfile auto-loads .env (see `dotenv:` in Taskfile.yaml).

# GoatCounter API token used by layouts/partials/popular-data.html to
# populate the Popular section. Token must have "Read statistics" scope.
# Without this set, the Popular section is omitted and a warning is logged.
GOAT_COUNTER_API=
